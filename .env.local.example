# ─── LiveKit Cloud（必須） ────────────────────────────────────────
# https://cloud.livekit.io → プロジェクトの Settings → Keys から取得
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_URL=wss://your-project.livekit.cloud

# ─── Discord OAuth2 認証（必須） ──────────────────────────────────
# https://discord.com/developers/applications でアプリ作成後に取得
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
# プライマリ Discord サーバーの Guild ID（このサーバーのメンバーのみ参加可）
DISCORD_GUILD_ID=
# 講師の Discord User ID をカンマ区切りで列挙（推奨。User ID で講師判定する）
DISCORD_INSTRUCTOR_USER_IDS=

# ─── セッション署名鍵（必須） ────────────────────────────────────
# JWT署名用。32バイト以上のランダム値推奨
# 生成例: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# ─── 追加で許可する Discord サーバー（任意） ──────────────────────
# 追加で入室を許可する Guild ID をカンマ区切り。
# いずれかの許可 guild に所属していれば入室可。講師判定は User ID で行うため
# どの guild から来ても DISCORD_INSTRUCTOR_USER_IDS の該当者は instructor。
DISCORD_ADDITIONAL_GUILD_IDS=

# ─── 後方互換（新運用では未使用） ────────────────────────────────
# 旧来のロールベース講師判定。DISCORD_INSTRUCTOR_USER_IDS を設定していれば
# 実質上書きされる。新規には使用しない。
DISCORD_INSTRUCTOR_ROLE_ID=

# ─── サーバー間呼び出し / EchoNote 連携（任意） ───────────────────
# EchoNote から /api/invite-token を Discord 認証なしで叩く際の共有秘密。
# EchoNote 側の JISHUSHITSU_SERVICE_SECRET と一致させる。
SERVICE_SHARED_SECRET=

# ─── EchoNote 連携（任意 / 講師ごとに別々のEchoNoteを設定可能） ────
# 講師の Discord User ID をキーに、その講師の EchoNote URL/Token を紐付けます。
# INSTRUCTOR_1, INSTRUCTOR_2, ... のように N を 1〜10 まで増やせます。
# 設定が無い講師は録音→要約フローが無効化され、終了モーダルは
# 「全員終了」「自分だけ退出」のみのシンプルな表示になります。
#
# 例: 元沢 講師
INSTRUCTOR_1_DISCORD_ID=
INSTRUCTOR_1_ECHONOTE_URL=
INSTRUCTOR_1_ECHONOTE_TOKEN=
# 例: 塚越 講師
INSTRUCTOR_2_DISCORD_ID=
INSTRUCTOR_2_ECHONOTE_URL=
INSTRUCTOR_2_ECHONOTE_TOKEN=
