# LiveKit Cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_URL=wss://your-project.livekit.cloud

# ─── Discord OAuth2 認証（必須） ──────────────────────────────────
# https://discord.com/developers/applications でアプリ作成後に取得
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
# 対象 Discord サーバーの Guild ID (このサーバーのメンバーのみ参加可)
DISCORD_GUILD_ID=
# 講師ロールの Role ID (このロールを持つメンバーが instructor 権限)
DISCORD_INSTRUCTOR_ROLE_ID=

# ─── セッション署名鍵（必須） ────────────────────────────────────
# JWT署名用。32バイト以上のランダム値推奨
# 生成例: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# ─── EchoNote 連携（任意 / 講師ごとに別々のEchoNoteを設定可能） ────
# 講師の Discord User ID をキーに紐付けます。
# 設定が無い講師はセッション終了時に「自分だけ退出」のみ可能になる。
# INSTRUCTOR_1, INSTRUCTOR_2, ... のように番号を増やせます。
#
# 例: 元沢 講師
INSTRUCTOR_1_DISCORD_ID=
INSTRUCTOR_1_ECHONOTE_URL=
INSTRUCTOR_1_ECHONOTE_TOKEN=
# 例: 塚越 講師
INSTRUCTOR_2_DISCORD_ID=
INSTRUCTOR_2_ECHONOTE_URL=
INSTRUCTOR_2_ECHONOTE_TOKEN=

# ─── 招待モーダルの送信先（任意） ────────────────────────────────
# Discord 用 Webhook URL（チャンネル設定 → 連携サービス → Webhook 作成）
DISCORD_WEBHOOK_URL=
# Slack 用 Incoming Webhook URL
SLACK_WEBHOOK_URL=
