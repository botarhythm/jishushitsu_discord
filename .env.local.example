# LiveKit Cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_URL=wss://your-project.livekit.cloud

# 講師認証キー（32文字以上のランダム文字列を推奨）
# 生成例: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INSTRUCTOR_KEY_MOTOZAWA=
INSTRUCTOR_KEY_TSUKAKOSHI=

# ─── EchoNote 連携（任意 / 講師ごとに別々のEchoNoteを設定可能）────────
# 各講師は自分のEchoNoteインスタンスをデプロイし、対応する変数を埋める。
# 設定が無い講師はセッション終了時に「自分だけ退出」のみ可能になる。
#
# 元沢 講師の EchoNote
ECHONOTE_URL_MOTOZAWA=
ECHONOTE_TOKEN_MOTOZAWA=
# 塚越 講師の EchoNote
ECHONOTE_URL_TSUKAKOSHI=
ECHONOTE_TOKEN_TSUKAKOSHI=

# ─── 招待モーダルの送信先（任意） ────────────────────────────────
# Discord 用 Webhook URL（チャンネル設定 → 連携サービス → Webhook 作成）
DISCORD_WEBHOOK_URL=
# Slack 用 Incoming Webhook URL
SLACK_WEBHOOK_URL=
