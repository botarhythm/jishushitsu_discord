# ─── LiveKit ─────────────────────────────────────────────────
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ─── Discord OAuth (講師ログイン用) ────────────────────────────
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
# プライマリの Discord サーバー ID
DISCORD_GUILD_ID=
# 追加で許可するサーバー ID をカンマ区切りで列挙 (例: デジハラ第1期 1500085001717420134)
DISCORD_ADDITIONAL_GUILD_IDS=
# 講師ロール ID (プライマリ guild のロールを想定)
DISCORD_INSTRUCTOR_ROLE_ID=

# ─── Session JWT 秘密鍵 ──────────────────────────────────────
# 生成例: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
SESSION_SECRET=

# ─── サーバー間呼び出し (EchoNote 連携) ───────────────────────
# EchoNote の JISHUSHITSU_SERVICE_SECRET と一致させる。
# このシークレットを持つリクエストは Discord 認証なしで /api/invite-token を発行できる。
SERVICE_SHARED_SECRET=

# ─── EchoNote アップロード先 (任意) ────────────────────────────
ECHONOTE_INGEST_URL=
ECHONOTE_INGEST_TOKEN=

# ─── 招待モーダルの Webhook (任意) ────────────────────────────
DISCORD_WEBHOOK_URL=
SLACK_WEBHOOK_URL=
